# ── Build artifacts ──────────────────────────────────────────
target/
*.class
*.jar
*.war

# ── IDE & OS ─────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
out/
.vscode/
.DS_Store
Thumbs.db

# ── Git ──────────────────────────────────────────────────────
.git/
.gitattributes
.gitignore

# ── Sensitive / environment files ────────────────────────────
