.env
.env.local
.env.*.local

# ── Logs & temp ──────────────────────────────────────────────
*.log
logs/

# ── Documentation ────────────────────────────────────────────
README.md
docs/

# ── Docker files themselves (not needed in build context) ─────
docker-compose*.yml
